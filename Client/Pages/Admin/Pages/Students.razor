@inject HttpClient Http
@attribute [Authorize(Roles = "Admin")]
@page "/admin/students"
@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@inject ISnackbar Snackbar
@using Shared.DTOs
@using Shared.Entities


<h3>Diák hozzáadása</h3>




@if (classes.Count != 0)
{
	<EditForm Model="studentModel" OnValidSubmit="HandleAdd">
		<div class="mb-3">
			<label>név:</label>
			<InputText @bind-Value="studentModel.Name" class="form-control" />
		</div>
		<div class="mb-3">
			<label>Email:</label>
			<InputText @bind-Value="studentModel.Email" type="email" class="form-control" />
		</div>

		<div class="mb-3">
			<label>Jelszó:</label>
			<InputText @bind-Value="studentModel.Password" type="password" class="form-control" />
		</div>



		<div class="mb-3">
			<label>Válassz tantárgyat:</label>
			<InputSelect @bind-Value="studentModel.SchoolClassId" class="form-control">
				<option value="0">-- Kérlek válassz --</option>
				@foreach (var item in classes)
				{
					<option value="@item.Id">@item.Name</option>
				}
			
			</InputSelect>
		</div>
		<button type="submit" class="btn btn-primary">Hozzáadás</button>


	</EditForm>
}
else
{
	<h3>Betöltés...</h3>
}


<h3>Students</h3>
@if(students==null)
{
	<h4>Betöltés...</h4>
}
else
{
	<MudTable Items="@students" MultiSelection="true" Dense="true" SortLabel="Sort by" Filter="new Func<StudentDetailsDto, bool>(FilterFunc)" @bind-SelectedItems="selectedStudents" Hover="true" Breakpoint="Breakpoint.Sm">

		<ToolBarContent>
			<MudText Typo="Typo.h6">Diákok</MudText>
			<MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
			<MudSpacer  /> @* Ez eltolja a gombot a jobb szélre *@


			@if (selectedStudents.Any())
			{
				<MudButton Variant="Variant.Filled"
						   Color="Color.Error"
						   StartIcon="@Icons.Material.Filled.Delete"
						   OnClick="OnDeleteSelected"
						   Class="ml-4">
					Törlés (@selectedStudents.Count)
				</MudButton>
			}
		</ToolBarContent>

			<HeaderContent>
			<MudTh><MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.Name)"> Név</MudTableSortLabel></MudTh>
			<MudTh><MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.Email)"> Email</MudTableSortLabel></MudTh>
			<MudTh><MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.SchoolClassName)"> Osztály</MudTableSortLabel></MudTh>
			<MudTh><MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.BirthDate)"> Születési dátum</MudTableSortLabel></MudTh>
			</HeaderContent>
			<RowTemplate>
				<MudTd DataLabel="Név">@context.Name</MudTd>
			<MudTd DataLabel="Email">@context.Email</MudTd>
			<MudTd DataLabel="Osztály">@context.SchoolClassName</MudTd>
			<MudTd DataLabel="Születési dátum">@context.BirthDate</MudTd>
			</RowTemplate>

		<PagerContent>
			<MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100, int.MaxValue }"
						   RowsPerPageString="Sorok száma oldalanként"
						   InfoFormat="{first_item}-{last_item} elem a {all_items}-ból"
						   AllItemsText="Összes"
						   HorizontalAlignment="HorizontalAlignment.Right"
						    />
		</PagerContent>
		
	</MudTable>


	
	
}

@code {


	private List<SchoolClassDto> classes = new List<SchoolClassDto>();
	private HashSet<string> selectedSubjects = new HashSet<string>();
	private StudentDetailsDto studentModel = new();

	private async Task HandleAdd()
	{
		{
			//if (studentModel.SchoolClass == null) return;

			studentModel.BirthDate = DateOnly.FromDateTime(DateTime.Now);
			studentModel.SchoolClassName = classes.FirstOrDefault(c => c.Id == studentModel.SchoolClassId).Name;
			var response = await Http.PostAsJsonAsync("api/students", studentModel);
			if (response.IsSuccessStatusCode)
			{
				StudentDetailsDto newStudent = await response.Content.ReadFromJsonAsync<StudentDetailsDto>();
				if (newStudent != null)
				{
					students.Add(newStudent);
					Snackbar.Add($"Sikeres hozzáadás", Severity.Success);
				}
			}

		}
	}

	private HashSet<StudentDetailsDto> selectedStudents = new ();
	private List<StudentDetailsDto> students = null;
	private string searchString = "";
	protected override async Task OnInitializedAsync()
	{
		var response = await Http.GetFromJsonAsync<List<SchoolClassDto>>("api/classes");
		if (response != null) classes = response;

		var response2 = await Http.GetFromJsonAsync<List<StudentDetailsDto>>("api/students");
		if (response2 != null) students = response2;

	}
	private async Task OnDeleteSelected()
	{
		Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
		var idsToDelete = selectedStudents.Select(s => s.Id).ToList();
		if (!idsToDelete.Any()) return;
		var response = await Http.PostAsJsonAsync("api/students/bulk-delete", idsToDelete);

		if (response.IsSuccessStatusCode)
		{	
			students.RemoveAll(s => idsToDelete.Contains(s.Id));
			selectedStudents.Clear();
			Snackbar.Add($"{idsToDelete.Count} diák törölve.", Severity.Success);
			StateHasChanged();
		}
		else Snackbar.Add($"Sikertelen", Severity.Error);

	}
	private bool FilterFunc(StudentDetailsDto student)
	{
		if (string.IsNullOrWhiteSpace(searchString))
			return true;
		if (student.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.SchoolClassName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.BirthDate.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		
		return false;
	}
}
