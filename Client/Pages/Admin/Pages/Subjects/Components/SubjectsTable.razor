@using MudBlazor
@using Shared.DTOs
@inject ISnackbar Snackbar
@inject HttpClient Http
<MudTable Items="@Subjects" MultiSelection="true" Dense="true" SortLabel="Sort by"
          Filter="new Func<SubjectDto, bool>(FilterFunc)" @bind-SelectedItems="selectedSubjects" Hover="true"
          Breakpoint="Breakpoint.Sm">

    <ToolBarContent>
        <MudText Typo="Typo.h6">Subjects</MudText>
        <MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        <MudSpacer/> 


        @if (selectedSubjects.Any())
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="@OnDeleteSelected"
                       Class="ml-4">
                Delete (@selectedSubjects.Count)
            </MudButton>
        }
    </ToolBarContent>

    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<SubjectDto, object>(x => x.Id)"> ID</MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<SubjectDto, object>(x => x.Name)"> Name</MudTableSortLabel>
        </MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Id">@context.Id</MudTd>
        <MudTd DataLabel="Name">@context.Name</MudTd>
    </RowTemplate>

    <PagerContent>
        <MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100, int.MaxValue }"
                       RowsPerPageString="Rows per page:"
                       InfoFormat="{first_item}-{last_item} of {all_items}"
                       AllItemsText="All"
                       HorizontalAlignment="HorizontalAlignment.Right"
        />
    </PagerContent>

</MudTable>

@code {
    [Parameter] public List<SubjectDto> Subjects { get; set; }
    private string searchString = "";
    private HashSet<SubjectDto> selectedSubjects = new HashSet<SubjectDto>();

    private async Task OnDeleteSelected()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
        var idsToDelete = selectedSubjects.Select(s => s.Id).ToList();
        if (!idsToDelete.Any()) return;
        var response = await Http.PostAsJsonAsync("api/subjects/bulk-delete", idsToDelete);

        if (response.IsSuccessStatusCode)
        {
            Subjects.RemoveAll(s => idsToDelete.Contains(s.Id));
            selectedSubjects.Clear();
            Snackbar.Add($"{idsToDelete.Count} subject(s) Deleted.", Severity.Success);
            StateHasChanged();
        }
        else Snackbar.Add($"Error", Severity.Error);
    }

    private bool FilterFunc(SubjectDto subject)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (subject.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (subject.Id.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

}