@using MudBlazor
@inject ISnackbar Snackbar
@inject HttpClient Http
@using Shared.DTOs
<MudTable Items="@Students" MultiSelection="true" Dense="true" SortLabel="Sort by"
          Filter="new Func<StudentDetailsDto, bool>(FilterFunc)" @bind-SelectedItems="selectedStudents" Hover="true"
          Breakpoint="Breakpoint.Sm">

	<ToolBarContent>
		<MudText Typo="Typo.h6">Students</MudText>
		<MudTextField @bind-Value="searchString" Placeholder="Search" Adornment="Adornment.Start"
		              AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
		              Class="mt-0"></MudTextField>
		<MudSpacer/> 


		@if (selectedStudents.Any())
		{
			<MudButton Variant="Variant.Filled"
			           Color="Color.Error"
			           StartIcon="@Icons.Material.Filled.Delete"
			           OnClick="@OnDeleteSelected"
			           Class="ml-4">
				Delete (@selectedStudents.Count)
			</MudButton>
		}
	</ToolBarContent>

	<HeaderContent>
		<MudTh>
			<MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.Name)"> Name</MudTableSortLabel>
		</MudTh>
		<MudTh>
			<MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.Email)"> Email</MudTableSortLabel>
		</MudTh>
		<MudTh>
			<MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.SchoolClassName)"> Class
			</MudTableSortLabel>
		</MudTh>
		<MudTh>
			<MudTableSortLabel SortBy="new Func<StudentDetailsDto, object>(x => x.BirthDate)"> Birth Date
			</MudTableSortLabel>
		</MudTh>
	</HeaderContent>
	<RowTemplate>
		<MudTd DataLabel="Name">@context.Name</MudTd>
		<MudTd DataLabel="Email">@context.Email</MudTd>
		<MudTd DataLabel="Class">@context.SchoolClassName</MudTd>
		<MudTd DataLabel="Birthdate">@context.BirthDate</MudTd>
	</RowTemplate>

	<PagerContent>
		<MudTablePager PageSizeOptions="new int[] { 10, 25, 50, 100, int.MaxValue }"
		               RowsPerPageString="Rows per page:"
		               InfoFormat="{first_item}-{last_item} of {all_items}"
		               AllItemsText="All"
		               HorizontalAlignment="HorizontalAlignment.Right"
		/>
	</PagerContent>

</MudTable>

@code {
	[Parameter] public required List<StudentDetailsDto> Students { get; set; }

	private HashSet<StudentDetailsDto> selectedStudents = new();
	private string searchString = "";

	private async Task OnDeleteSelected()
	{
		Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
		var idsToDelete = selectedStudents.Select(s => s.Id).ToList();
		if (!idsToDelete.Any()) return;
		var response = await Http.PostAsJsonAsync("api/students/bulk-delete", idsToDelete);

		if (response.IsSuccessStatusCode)
		{
			Students.RemoveAll(s => idsToDelete.Contains(s.Id));
			selectedStudents.Clear();
			Snackbar.Add($"{idsToDelete.Count} student(s) deleted.", Severity.Success);
			StateHasChanged();
		}
		else Snackbar.Add($"Error", Severity.Error);
	}

	private bool FilterFunc(StudentDetailsDto student)
	{
		if (string.IsNullOrWhiteSpace(searchString))
			return true;
		if (student.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.SchoolClassName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;
		if (student.BirthDate.ToString().Contains(searchString, StringComparison.OrdinalIgnoreCase))
			return true;

		return false;
	}

}