
@using MudBlazor
@using Shared.DTOs
<EditForm Model="ClassModel" OnValidSubmit="HandleSubmit">

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Class="mb-3">

        <MudTextField @bind-Value="ClassModel.Name"
                      Label="Name"
                      Variant="Variant.Text"
                      Style="max-width: 300px;"/>

        <MudNumericField @bind-Value="ClassModel.Year"
                         Label="Year"
                         Variant="Variant.Text"
                         Style="max-width: 300px;"/>

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Class="mt-4">
            Add
        </MudButton>

    </MudStack>

</EditForm>

@code {
    [Parameter] public required SchoolClassDto ClassModel { get; set; }

    [Parameter] public required EventCallback<SchoolClassDto> OnSubmit { get; set; }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync(ClassModel);
    }

}