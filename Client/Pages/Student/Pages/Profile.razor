@page "/student/profile"
@using Client.Pages.Components
@using Microsoft.AspNetCore.Authorization
@using MudBlazor

@using Shared.DTOs
@attribute [Authorize(Roles = "Student")]
@inject HttpClient Http
@inject ISnackbar Snackbar
<h3>Profile</h3>

@if (student == null)
{
    <LoadingCircle/>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard Elevation="3" Class="pa-4" Style="height: 100%;">
                    <MudCardHeader>
                     
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">@student.Name</MudText>
                           
                        </CardHeaderContent>
                    </MudCardHeader>

                    <MudCardContent>
                        <MudList T="string">
                            <MudListItem Icon="@Icons.Material.Filled.Email" Text="@($"Email: {student.Email}")"/>
                            <MudListItem Icon="@Icons.Material.Filled.Cake"
                                         Text="@($"Születési dátum: {student.BirthDate?.ToString("yyyy. MM. dd.") ?? "Nincs megadva"}")"/>
                            <MudListItem Icon="@Icons.Material.Filled.Class"
                                         Text="@($"Osztály: {student.SchoolClassName}")"/>
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard Elevation="3" Class="pa-4" Style="height: 100%;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Jelszó megváltoztatása</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>

                    <MudCardContent>
                        <EditForm Model="@passwordModel" OnValidSubmit="HandlePasswordChange">
                            <DataAnnotationsValidator/>

                            <MudTextField T="string"
                                          Label="Jelenlegi jelszó"
                                          @bind-Value="passwordModel.CurrentPassword"
                                          For="@(() => passwordModel.CurrentPassword)"
                                          InputType="@currentPasswordInput"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@currentPasswordIcon"
                                          OnAdornmentClick="ToggleCurrentPasswordVisibility"
                                          Variant="Variant.Outlined"
                                          Class="mb-4"/>

                            <MudTextField T="string"
                                          Label="Új jelszó"
                                          @bind-Value="passwordModel.NewPassword"
                                          For="@(() => passwordModel.NewPassword)"
                                          InputType="@newPasswordInput"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@newPasswordIcon"
                                          OnAdornmentClick="ToggleNewPasswordVisibility"
                                          Variant="Variant.Outlined"
                                          Class="mb-4"/>

                            <MudTextField T="string"
                                          Label="Új jelszó megerősítése"
                                          @bind-Value="passwordModel.ConfirmPassword"
                                          For="@(() => passwordModel.ConfirmPassword)"
                                          InputType="@newPasswordInput"
                                          Variant="Variant.Outlined"
                                          Class="mb-6"/>

                            <div class="d-flex justify-end">
                                <MudButton ButtonType="ButtonType.Submit"
                                           Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                        <MudText Class="ms-2">Mentés...</MudText>
                                    }
                                    else
                                    {
                                        <MudText>Mentés</MudText>
                                    }
                                </MudButton>
                            </div>
                        </EditForm>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    </MudContainer>
}
