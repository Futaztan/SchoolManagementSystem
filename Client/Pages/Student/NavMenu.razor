@using Client.Token
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager

<MudNavMenu Bordered="true">
    <MudText Typo="Typo.h6" Class="px-4 py-3" Color="Color.Primary">Student Panel</MudText>
    
    <MudNavLink Href="student/home" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">
        Home
    </MudNavLink>
    
    <MudNavLink Href="student/grades" Icon="@Icons.Material.Filled.Grade">
        Grades
    </MudNavLink>
    
    <MudNavLink Href="student/courses" Icon="@Icons.Material.Filled.Class">
        Courses
    </MudNavLink>
    
    <MudNavLink Href="student/profile" Icon="@Icons.Material.Filled.Person">
        Profile
    </MudNavLink>

    <MudDivider Class="my-2" />

    <div class="px-4 py-2">
        <MudButton Variant="Variant.Filled" 
                   Color="Color.Error" 
                   FullWidth="true"
                   StartIcon="@Icons.Material.Filled.Logout"
                   OnClick="@Logout">
            Sign out
        </MudButton>
    </div>
</MudNavMenu>

@code {
    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        ((CustomAuthStateProvider)AuthStateProvider).NotifyUserLogout();
        NavManager.NavigateTo("/");
    }
}